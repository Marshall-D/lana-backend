# Copy to .env and fill in values.

# Required
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xyz.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here

# Password reset JWT (prefer a separate secret in production; falls back to JWT_SECRET)
JWT_RESET_SECRET=your_reset_secret_here
JWT_RESET_EXPIRES=15m

# Access JWT (short-lived). Prefer this after rotation work:
JWT_ACCESS_EXPIRES=15m
# Legacy alias — used only if JWT_ACCESS_EXPIRES is unset:
# JWT_LIFETIME=15m

# Refresh token lifetime (override code default). Example: 2m for testing expiry.
JWT_REFRESH_EXPIRES=2m
# Legacy alias — used only if JWT_REFRESH_EXPIRES is unset:
# JWT_REFRESH_LIFETIME=15m

PORT=3000
